<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <title>Sollutionns Drive Pro</title>
    <link rel="manifest" href="manifest.json">
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <style>
        :root { --blue: #0066b2; --bg: #05070a; }
        body { margin: 0; background: var(--bg); color: white; font-family: sans-serif; height: 100dvh; display: flex; flex-direction: column; overflow: hidden; }
        header { padding: 40px 20px 10px; text-align: center; background: #000; border-bottom: 1px solid #222; }
        #map { flex: 1; width: 100%; }
        .controls { padding: 20px; background: rgba(10,15,25,0.95); border-radius: 20px 20px 0 0; }
        .timer { font-size: 2.5rem; text-align: center; margin-bottom: 15px; color: var(--blue); font-family: monospace; }
        .btn { width: 100%; padding: 18px; border-radius: 12px; border: none; font-weight: bold; font-size: 1rem; color: white; background: var(--blue); }
        .btn-stop { background: #d00; margin-top: 10px; }
        .stats { display: flex; justify-content: space-around; margin-top: 15px; font-size: 0.8rem; color: #aaa; }
    </style>
</head>
<body>

<header>SOLLUTIONNS <b>DRIVE PRO</b></header>

<div id="map"></div>

<div class="controls">
    <div class="timer" id="stopwatch">00:00:00</div>
    <button id="btnStart" class="btn" onclick="startDrive()">INICIAR VIAGEM</button>
    <button id="btnStop" class="btn btn-stop" onclick="stopDrive()" style="display:none">ENCERRAR</button>
    
    <div class="stats">
        <div>DISTÂNCIA: <span id="dist" style="color:white">0.0</span> km</div>
        <div>VELOCIDADE: <span id="speed" style="color:white">0</span> km/h</div>
    </div>
</div>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
    let map, path = [], polyline, watchId, startTime;

    // Inicializa o Mapa
    map = L.map('map', { zoomControl: false, attributionControl: false }).setView([0,0], 15);
    L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png').addTo(map);
    polyline = L.polyline([], {color: '#0066b2', weight: 6}).addTo(map);
    let marker = L.circleMarker([0,0], {radius: 7, color: '#fff', fillColor: '#0066b2', fillOpacity: 1}).addTo(map);

    function startDrive() {
        path = [];
        startTime = Date.now();
        document.getElementById('btnStart').style.display = 'none';
        document.getElementById('btnStop').style.display = 'block';

        // GPS EM TEMPO REAL (Alta Precisão)
        watchId = navigator.geolocation.watchPosition(pos => {
            const { latitude, longitude, speed } = pos.coords;
            const currentPos = [latitude, longitude];
            
            path.push(currentPos);
            polyline.setLatLngs(path);
            marker.setLatLng(currentPos);
            map.flyTo(currentPos, 17); // Segue o carro

            if(speed) document.getElementById('speed').innerText = Math.round(speed * 3.6);
            
            // Cálculo simples de distância (opcional: usar fórmula de haversine para precisão real)
            document.getElementById('dist').innerText = (path.length * 0.005).toFixed(2); 

        }, null, { enableHighAccuracy: true, maximumAge: 0 });

        // Cronômetro
        timerInterval = setInterval(() => {
            let d = new Date(Date.now() - startTime);
            document.getElementById('stopwatch').innerText = d.toISOString().substr(11, 8);
        }, 1000);
    }

    function stopDrive() {
        navigator.geolocation.clearWatch(watchId);
        clearInterval(timerInterval);
        document.getElementById('btnStart').style.display = 'block';
        document.getElementById('btnStop').style.display = 'none';
        map.fitBounds(polyline.getBounds());
    }

    // Registro do PWA
    if ('serviceWorker' in navigator) {
        navigator.serviceWorker.register('sw.js');
    }
</script>
</body>
</html>
